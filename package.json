{
  "name": "@zcrystal/openclaw-plugin",
  "version": "1.0.2",
  "type": "module",
  "description": "ZCrystal Plugin for OpenClaw - Proactive AI + Self-Evolution + Skills System",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.4.12",
      "minGatewayVersion": "2026.4.15"
    },
    "build": {
      "openclawVersion": "2026.4.15",
      "pluginSdkVersion": "2026.4.12"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "setup": "bash setup.sh",
    "postinstall": "bash scripts/setup-evo.sh && npm run build"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "@zcrystal/evo": "file:./node_modules/@zcrystal/evo",
    "fuse.js": "^7.0.0",
    "openclaw": "^2026.4.15"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "openclaw",
    "zcrystal",
    "plugin",
    "ai",
    "self-evolution",
    "proactive",
    "skills",
    "workflow",
    "memory-layers"
  ],
  "bin": {
    "zcrystal-setup": "./setup.sh"
  }
}